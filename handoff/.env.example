# URL de tu proyecto Supabase (ej: https://abcdxyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública "anon" (segura para el navegador)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
